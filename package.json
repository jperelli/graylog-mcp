{
  "name": "@jperelli/graylog-mcp",
  "version": "1.1.0",
  "description": "MCP server for fetching data from Graylog",
  "mcpName": "io.github.jperelli/graylog-mcp",
  "main": "src/index.js",
  "bin": {
    "graylog-mcp": "src/index.js"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jperelli/graylog-mcp.git"
  },
  "homepage": "https://github.com/jperelli/graylog-mcp#readme",
  "bugs": {
    "url": "https://github.com/jperelli/graylog-mcp/issues"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "test": "node --test test/*.test.js",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write"
  },
  "keywords": [
    "mcp",
    "graylog",
    "logging",
    "model-context-protocol"
  ],
  "author": "Julian Perelli <jperelli@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3"
  }
}
